// ══════════════════════════════════════════════════
// CROSS-TABLE REFS — BỔ SUNG G (bảng mới Session 14)
// ══════════════════════════════════════════════════

// ── G1. package tracking → inside_package_history ────
Ref: raw.pickup_delivery__dtr_insidev3__package.code > clean.inside_package_history.package_code

// ── G2. dev.parsed_transportation_history ↔ clean ────
Ref: dev.parsed_transportation_history.trip_code > fa.logistics_trip_detail.code
Ref: sorting_core.truck_north.trip_code > dev.parsed_transportation_history.trip_code
Ref: clean.inside_package_history.trip_code > dev.parsed_transportation_history.trip_code

// ── G3. truck stop metrics → transportation ──────────
Ref: raw.ws_report__report_dashboard__truck_stop_metrics.trip_code > clean.parsed_transportation_history.trip_code
Ref: raw.ws_report__report_dashboard__truck_stop_metrics.trip_code > dev.parsed_transportation_history.trip_code

// ── G4. CDC changelog → core fact ────────────────────
Ref: raw.online_core_corev2_shippingorder.new_order_code > data_internalv2.data_shippingorder_now.order_code

// ── G5. sorting_core order_code facts → shippingorder ─
Ref: sorting_core.qua_kho.order_code > data_internalv2.data_shippingorder_now.order_code
Ref: sorting_core.cho_ra.order_code > data_internalv2.data_shippingorder_now.order_code
Ref: sorting_core.cho_dong.order_code > data_internalv2.data_shippingorder_now.order_code
Ref: sorting_core.cho_xuat_new.order_code > data_internalv2.data_shippingorder_now.order_code
Ref: sorting_core.theo_doi_shipper.order_code > data_internalv2.data_shippingorder_now.order_code
Ref: sorting_core.inventory_north_detail.order_code > data_internalv2.data_shippingorder_now.order_code

// ── G6. receive_export_north → transportation ─────────
Ref: sorting_core.receive_export_north.trip_code > clean.parsed_transportation_history.trip_code

// ── G7. cho_ra → transportation ──────────────────────
Ref: sorting_core.cho_ra.trip_code > clean.parsed_transportation_history.trip_code
