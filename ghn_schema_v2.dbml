// ═══════════════════════════════════════════════════════════════════════
// GHN Data Warehouse — Schema & Relationships (v2, tổng hợp từ MCP)
// Engine : Trino / Iceberg + dw-ghn
// Cập nhật: 2026-05-22
//
// Cách dùng: Paste vào diagram tool tại project/Datamapping/dbml-diagram.html
// Ref notation: ref: > schema.table.col  (3-part, cross-schema)
// database: attribute → dùng để phân cấp UI Library Panel
// ═══════════════════════════════════════════════════════════════════════


// ══════════════════════════════════════════════════
// LAYER 0 — LOCATION HIERARCHY (ref tables)
// Hệ thống địa chính VN: Tỉnh → Quận → Phường
// ══════════════════════════════════════════════════

Table dwh.dim_location_province [note: 'ref', database: 'iceberg'] {
  province_id       bigint  [pk, note: 'Mã tỉnh/thành (PK)']
  province_name     varchar [note: 'Tên tỉnh/thành']
  province_status   bigint
  region_id         bigint
  region_name       varchar
  region_shortname  varchar [note: 'HNO / HCM / DNB …']
  region_fullname   varchar
  region_code_hrw   varchar
}

Table dwh.dim_location_district [note: 'ref', database: 'iceberg'] {
  district_id      bigint  [pk, note: 'Mã quận/huyện (PK)']
  district_code    varchar [note: 'Mã số quận/huyện (string)']
  district_name    varchar
  district_type    varchar
  district_status  bigint
  province_id      bigint  [ref: > dwh.dim_location_province.province_id, note: 'FK → tỉnh']
  province_name    varchar
  region_id        bigint
  region_name      varchar
  region_fullname  varchar
  region_shortname varchar
  region_code_hrw  varchar
}

Table dwh.dim_location_ward [note: 'ref', database: 'iceberg'] {
  ward_id          varchar [pk, note: 'Mã phường/xã (PK, = ward_code)']
  ward_name        varchar
  ward_status      bigint
  district_id      bigint  [ref: > dwh.dim_location_district.district_id, note: 'FK → quận']
  district_code    varchar
  district_name    varchar
  district_type    varchar
  province_id      bigint  [ref: > dwh.dim_location_province.province_id, note: 'FK → tỉnh']
  province_name    varchar
  region_id        bigint
  region_name      varchar
  region_fullname  varchar
  region_shortname varchar
  region_code_hrw  varchar
}


// ══════════════════════════════════════════════════
// LAYER 1 — CORE DIMENSIONS (dwh)
// ══════════════════════════════════════════════════

Table dwh.dim_client [note: 'dim', database: 'iceberg'] {
  client_id   bigint  [pk, note: 'Mã khách hàng / shop (PK)']
  client_name varchar [note: 'Tên shop']
  client_type varchar [note: 'KA / non-KA / B2B …']
}

Table dwh.dim_warehouse [note: 'dim', database: 'iceberg'] {
  warehouse_id        bigint  [pk, note: 'Mã kho/bưu cục (PK)']
  department_id       bigint  [ref: > dwh.dim_department._id, note: 'FK → chi nhánh/đơn vị']
  warehouse_name      varchar
  warehouse_address   varchar
  warehouse_type      varchar [note: 'BC / KTC / TTS / HUB …']
  is_enabled          boolean
  status_hrw          bigint  [note: 'Trạng thái HRW']
  is_virtual          varchar
  ward_code           varchar [note: 'Mã phường (không join trực tiếp)']
  ward_name           varchar
  district_id         bigint  [ref: > dwh.dim_location_district.district_id, note: 'FK → quận']
  district_name       varchar
  province_id         bigint  [ref: > dwh.dim_location_province.province_id, note: 'FK → tỉnh']
  province_name       varchar
  region_shortname    varchar
  region_fullname     varchar
  team_name           varchar
  section_name        varchar
  department_name     varchar
  gdv_id              bigint  [note: 'FK → dim_employee (giám đốc vùng)']
  gdv_name            varchar
  pgdv_id             bigint  [note: 'FK → dim_employee (phó GĐV)']
  pgdv_name           varchar
  area_manager_id     bigint  [note: 'FK → dim_employee']
  area_manager_name   varchar
  station_leader_id   bigint  [note: 'FK → dim_employee']
  station_leader_name varchar
  owner_location_id   varchar
  latitude            double
  longitude           double
  created_time        timestamp
  last_updated_time   timestamp
  hrw_updated_at      timestamp
}

Table dwh.dim_employee [note: 'dim', database: 'iceberg'] {
  employee_id      bigint  [pk, note: 'Mã nhân viên (PK)']
  hara_id          decimal [note: 'Mã Hara (ID quốc tế)']
  employee_name    varchar
  jobtitle_id      bigint
  jobtitle_name    varchar [note: 'Chức danh EN']
  jobtitle_name_vn varchar [note: 'Chức danh VN']
  status           varchar [note: 'active / inactive']
  type             double  [note: 'Loại nhân viên']
  unit_id          double  [note: 'FK → đơn vị']
  warehouse_id     bigint  [ref: > dwh.dim_warehouse.warehouse_id, note: 'FK → kho làm việc']
  group_id         bigint
  group_name       varchar
  team_id          bigint
  team_name        varchar
  section_id       bigint
  section_name     varchar
  department_id    bigint
  department_name  varchar
  division_id      bigint
  division_name    varchar
  bu_id            bigint
  bu_name          varchar
  start_working_date timestamp
  termination_date   timestamp
}


// ══════════════════════════════════════════════════
// LAYER 2 — CORE FACT: SHIPPING ORDER
// Bảng trung tâm — mọi domain đều join về đây qua order_code
// Schema: dw-ghn / data_internalv2
// Tên thực: data_shippingorder_now (có prefix data_)
// ══════════════════════════════════════════════════

Table data_internalv2.data_shippingorder_now [note: 'fact', database: 'dw-ghn'] {
  order_code           varchar [pk, note: 'Mã đơn hàng (PK)']
  client_id            bigint  [ref: > dwh.dim_client.client_id, note: 'FK → shop']
  shop_id              bigint  [note: 'Mã cửa hàng (sub-entity của client)']

  // ── Địa chỉ gửi
  from_ward_code       varchar [ref: > dwh.dim_location_ward.ward_id, note: 'FK → phường gửi']
  from_district_id     bigint  [ref: > dwh.dim_location_district.district_id, note: 'FK → quận gửi']
  from_name            varchar
  from_phone           varchar [note: 'PII.Sensitive']
  from_address         varchar

  // ── Địa chỉ nhận
  to_ward_code         varchar [ref: > dwh.dim_location_ward.ward_id, note: 'FK → phường nhận']
  to_district_id       bigint  [ref: > dwh.dim_location_district.district_id, note: 'FK → quận nhận']
  to_phone             varchar [note: 'PII.Sensitive']

  // ── Kho vận
  pick_warehouse_id    bigint  [ref: > dwh.dim_warehouse.warehouse_id, note: 'FK → kho lấy hàng']
  deliver_warehouse_id bigint  [ref: > dwh.dim_warehouse.warehouse_id, note: 'FK → kho giao hàng']
  current_warehouse_id bigint  [ref: > dwh.dim_warehouse.warehouse_id, note: 'FK → kho hiện tại']
  return_warehouse_id  bigint  [ref: > dwh.dim_warehouse.warehouse_id, note: 'FK → kho trả hàng']

  // ── Nhân sự
  pick_user            bigint  [ref: > dwh.dim_employee.employee_id, note: 'FK → shipper lấy hàng']
  deliver_user         bigint  [ref: > dwh.dim_employee.employee_id, note: 'FK → shipper giao hàng']
  return_user          bigint  [ref: > dwh.dim_employee.employee_id, note: 'FK → shipper trả hàng']

  // ── Trạng thái & loại
  status               varchar [note: 'ready_to_pick / picking / delivering / delivered / return …']
  action               varchar [note: 'Hành động gần nhất']
  type_order           varchar [note: 'freight / bulky / normal']
  type_order_code      varchar
  tag                  varchar [note: 'array — contains "bulky" nếu hàng cồng kềnh']
  is_b2b               boolean

  // ── Kích thước & tài chính
  weight               bigint  [note: 'gram']
  converted_weight     bigint  [note: 'gram quy đổi']
  length               bigint
  width                bigint
  height               bigint
  cod_amount           bigint  [note: 'VNĐ']
  cod_collect_date     timestamp
  cod_failed_amount    bigint  [note: 'COD thất bại']
  cod_failed_collect_date timestamp
  cod_amount_bk        bigint
  insurance_value      bigint
  pick_station_id      bigint

  // ── Nội dung & dịch vụ
  content              varchar
  note                 varchar
  created_source       varchar
  data                 varchar [note: 'JSON extra']
  items                varchar [note: 'JSON danh sách sản phẩm']
  deliver_shift        varchar [note: 'Ca giao hàng']
  extra_service        varchar [note: 'JSON dịch vụ mở rộng']

  // ── Mốc thời gian
  created_date         timestamp
  end_pick_time        timestamp
  first_delivered_time timestamp
  end_delivery_time    timestamp

  service_type_id      bigint
  service_id           bigint
}


// ══════════════════════════════════════════════════
// LAYER 2b — SHIPPING ORDER SNAPSHOTS (clean)
// 3 bảng phân vùng theo các mốc thời gian khác nhau
// Schema: iceberg / clean
// Cùng cấu trúc cột (~120 cột), khác partition field
// NOTE: chỉ document các cột thường dùng — xem MCP để full schema
// ══════════════════════════════════════════════════

Table clean.online_core_corev2_shippingorder_endpicktime [note: 'snapshot', database: 'iceberg'] {
  dt                   varchar   [note: 'PARTITION — end_pick_time (yyyy-MM-dd)']
  _id                  varchar   [note: 'Internal document ID']
  order_code           varchar   [pk, ref: > data_internalv2.data_shippingorder_now.order_code, note: 'FK → đơn hàng (snapshot theo end_pick_time)']
  client_id            bigint    [ref: > dwh.dim_client.client_id, note: 'FK → shop']
  shop_id              bigint

  // ── Địa chỉ gửi & nhận
  from_ward_code       varchar   [ref: > dwh.dim_location_ward.ward_id, note: 'FK → phường gửi']
  from_district_id     bigint    [ref: > dwh.dim_location_district.district_id, note: 'FK → quận gửi']
  to_ward_code         varchar   [ref: > dwh.dim_location_ward.ward_id, note: 'FK → phường nhận']
  to_district_id       bigint    [ref: > dwh.dim_location_district.district_id, note: 'FK → quận nhận']
  return_ward_code     varchar   [note: 'Mã phường trả hàng']
  return_district_id   bigint    [note: 'Mã quận trả hàng']

  // ── Kho vận
  pick_warehouse_id    bigint    [ref: > dwh.dim_warehouse.warehouse_id, note: 'FK → kho lấy hàng']
  deliver_warehouse_id bigint    [ref: > dwh.dim_warehouse.warehouse_id, note: 'FK → kho giao hàng']
  current_warehouse_id bigint    [ref: > dwh.dim_warehouse.warehouse_id, note: 'FK → kho hiện tại']
  return_warehouse_id  bigint    [ref: > dwh.dim_warehouse.warehouse_id, note: 'FK → kho trả hàng']
  next_warehouse_id    bigint    [note: 'Kho tiếp theo']

  // ── Nhân sự
  pick_user            bigint    [ref: > dwh.dim_employee.employee_id, note: 'FK → shipper lấy']
  deliver_user         bigint    [ref: > dwh.dim_employee.employee_id, note: 'FK → shipper giao']
  return_user          bigint    [note: 'FK → shipper trả']
  lost_user            bigint    [note: 'FK → nhân viên ghi nhận mất']

  // ── Trạng thái
  status               varchar
  action               varchar
  type_order           varchar   [note: 'freight / bulky / normal']
  tag                  varchar   [note: 'ARRAY<STRING> — bulky flag']
  is_b2b               boolean
  is_partial_return    boolean
  is_cod_collected     boolean
  sort_code            varchar

  // ── Kích thước & COD
  weight               bigint    [note: 'gram']
  converted_weight     bigint
  length               bigint
  width                bigint
  height               bigint
  cod_amount           varchar   [note: 'STRING (khác shippingorder_now là BIGINT)']
  payment_type_id      bigint
  client_order_code    varchar

  // ── Đếm lần thực hiện
  num_pick             bigint
  num_deliver          bigint
  num_return           bigint

  // ── Mốc thời gian
  created_date         timestamp
  end_pick_time        timestamp [note: 'PARTITION key']
  end_delivery_time    timestamp
  first_picked_time    timestamp
  return_time          timestamp
  s2r_time             timestamp
  end_return_time      timestamp
  end_success_time     timestamp
  lost_time            timestamp

  service_type_id      bigint
  service_id           bigint
  pick_station_id      bigint
}

Table clean.online_core_corev2_shippingorder_enddeliverytime [note: 'snapshot', database: 'iceberg'] {
  dt                   varchar   [note: 'PARTITION — end_delivery_time (yyyy-MM-dd)']
  _id                  varchar   [note: 'Internal document ID']
  order_code           varchar   [pk, ref: > data_internalv2.data_shippingorder_now.order_code, note: 'FK → đơn hàng (snapshot theo end_delivery_time)']
  client_id            bigint    [ref: > dwh.dim_client.client_id, note: 'FK → shop']
  shop_id              bigint

  // ── Địa chỉ gửi & nhận
  from_ward_code       varchar   [ref: > dwh.dim_location_ward.ward_id, note: 'FK → phường gửi']
  from_district_id     bigint    [ref: > dwh.dim_location_district.district_id, note: 'FK → quận gửi']
  to_ward_code         varchar   [ref: > dwh.dim_location_ward.ward_id, note: 'FK → phường nhận']
  to_district_id       bigint    [ref: > dwh.dim_location_district.district_id, note: 'FK → quận nhận']
  return_ward_code     varchar   [note: 'Mã phường trả hàng']
  return_district_id   bigint    [note: 'Mã quận trả hàng']

  // ── Kho vận
  pick_warehouse_id    bigint    [ref: > dwh.dim_warehouse.warehouse_id, note: 'FK → kho lấy hàng']
  deliver_warehouse_id bigint    [ref: > dwh.dim_warehouse.warehouse_id, note: 'FK → kho giao hàng']
  current_warehouse_id bigint    [ref: > dwh.dim_warehouse.warehouse_id, note: 'FK → kho hiện tại']
  return_warehouse_id  bigint    [ref: > dwh.dim_warehouse.warehouse_id, note: 'FK → kho trả hàng']
  next_warehouse_id    bigint    [note: 'Kho tiếp theo']

  // ── Nhân sự
  pick_user            bigint    [ref: > dwh.dim_employee.employee_id, note: 'FK → shipper lấy']
  deliver_user         bigint    [ref: > dwh.dim_employee.employee_id, note: 'FK → shipper giao']
  return_user          bigint    [note: 'FK → shipper trả']
  lost_user            bigint    [note: 'FK → nhân viên ghi nhận mất']

  // ── Trạng thái
  status               varchar
  action               varchar
  type_order           varchar   [note: 'freight / bulky / normal']
  tag                  varchar   [note: 'ARRAY<STRING> — bulky flag']
  is_b2b               boolean
  is_partial_return    boolean
  is_cod_collected     boolean
  sort_code            varchar

  // ── Kích thước & COD
  weight               bigint    [note: 'gram']
  converted_weight     bigint
  length               bigint
  width                bigint
  height               bigint
  cod_amount           varchar   [note: 'STRING']
  payment_type_id      bigint
  client_order_code    varchar

  // ── Đếm lần thực hiện
  num_pick             bigint
  num_deliver          bigint
  num_return           bigint

  // ── Mốc thời gian
  created_date         timestamp
  end_pick_time        timestamp
  end_delivery_time    timestamp [note: 'PARTITION key']
  first_picked_time    timestamp
  return_time          timestamp
  s2r_time             timestamp
  end_return_time      timestamp
  end_success_time     timestamp
  lost_time            timestamp

  service_type_id      bigint
  service_id           bigint
  pick_station_id      bigint
}

Table clean.online_core_corev2_shippingorder_createddate [note: 'snapshot', database: 'iceberg'] {
  dt                   varchar   [note: 'PARTITION — created_date (yyyy-MM-dd)']
  _id                  varchar   [note: 'Internal document ID']
  order_code           varchar   [pk, ref: > data_internalv2.data_shippingorder_now.order_code, note: 'FK → đơn hàng (snapshot theo created_date)']
  client_id            bigint    [ref: > dwh.dim_client.client_id, note: 'FK → shop']
  shop_id              bigint

  // ── Địa chỉ gửi & nhận
